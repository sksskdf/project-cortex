# GitHub App 인증 (Phase 3.4)
# 1) App ID — App 설정 페이지 상단의 숫자 (예: 1234567).
GITHUB_APP_ID=

# 2) App private key — "Generate a private key" 로 받은 .pem 내용 전체.
#    여러 줄이라 따옴표로 감싸고 개행은 그대로 유지하거나 \n 으로:
#    GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
#    MIIEpA...
#    -----END RSA PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY=

# 3) Webhook 시크릿 — App 등록 시 "Webhook secret" 칸에 입력한 값과 동일.
#    `openssl rand -hex 32` 로 무작위 생성 후 양쪽에 같은 값 입력.
GITHUB_WEBHOOK_SECRET=

# AI 사전 리뷰 (Phase 4) — Anthropic API key (Claude).
# https://console.anthropic.com/ → Settings → API Keys.
ANTHROPIC_API_KEY=

# DB 경로 (옵션). 미설정 시 data/cortex.sqlite.
CORTEX_DB_PATH=
