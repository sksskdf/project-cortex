# GitHub App 인증 (Phase 3.4)
# 1) App ID — App 설정 페이지 상단의 숫자 (예: 1234567).
GITHUB_APP_ID=

# 2) App private key — "Generate a private key" 로 받은 .pem 내용 전체.
#    여러 줄이라 따옴표로 감싸고 개행은 그대로 유지하거나 \n 으로:
#    GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
#    MIIEpA...
#    -----END RSA PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY=

# 3) Webhook 시크릿 — App 등록 시 "Webhook secret" 칸에 입력한 값과 동일.
#    `openssl rand -hex 32` 로 무작위 생성 후 양쪽에 같은 값 입력.
GITHUB_WEBHOOK_SECRET=

# AI 작업(사전 리뷰·충돌 해결·테스트 수정)은 로컬 claude CLI (사용자 Claude 플랜)로
# 동작합니다. 별도 API key 가 필요 없습니다 — 터미널에서 `claude` 가 로그인돼 있어야 합니다.
# (ANTHROPIC_API_KEY 가 환경에 있으면 claude 가 API 로 과금하므로 설정하지 마세요.)

# DB 경로 (옵션). 미설정 시 data/cortex.sqlite.
CORTEX_DB_PATH=

# Phase 4.5b — Haiku 1차 분류 활성화. '1' 이면 Haiku 가 먼저 PR 을 훑어
# 단순한 변경은 거기서 종료, 복잡 의심 PR 만 Opus 로 재호출.
# 미설정/'0' 이면 항상 Opus 직행 (기존 동작).
CORTEX_TRIAGE_ENABLED=

# Phase 7 — Sentry 에러 트래킹 (옵션). 미설정 시 Sentry 완전 비활성 — 로컬 dev 영향 없음.
# 설정하면 webhook 핸들러 등 중앙 에러 경로에서 예외가 Sentry 로 전송됩니다.
SENTRY_DSN=

# Sentry 환경 라벨 (옵션). 미설정 시 NODE_ENV 사용 (예: production / development).
SENTRY_ENVIRONMENT=
